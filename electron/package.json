{
  "name": "taskclf-electron",
  "version": "0.3.20",
  "description": "Local-first task classifier",
  "author": "fruitiecutiepie",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:icon": "node scripts/build-icon.js",
    "build": "pnpm run build:icon && tsc -p tsconfig.json",
    "start": "pnpm run build && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack": "electron-builder --dir",
    "dist": "pnpm run build:icon && electron-builder"
  },
  "build": {
    "appId": "com.github.fruitiecutiepie.taskclf",
    "productName": "taskclf",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "build/icon.png"
    ],
    "mac": {
      "icon": "icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/adm-zip": "0.5.8",
    "@types/node": "^25.5.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "adm-zip": "0.5.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
