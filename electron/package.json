{
  "name": "taskclf-electron",
  "version": "0.3.12",
  "description": "Local-first task classifier",
  "author": "fruitiecutiepie",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:icon": "mkdir -p build && uv run rsvg-convert -h 1024 ../assets/taskclf-icon.svg -o build/icon.png",
    "build": "pnpm run build:icon && tsc -p tsconfig.json",
    "start": "pnpm run build && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack": "electron-builder --dir",
    "dist": "pnpm run build:icon && electron-builder"
  },
  "build": {
    "appId": "com.github.fruitiecutiepie.taskclf",
    "productName": "taskclf",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "build/icon.png"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "../build/nuitka/entry.app/Contents/MacOS/",
          "to": "backend",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "extraResources": [
        {
          "from": "../build/nuitka/entry.dist/",
          "to": "backend",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "../build/nuitka/entry.dist/",
          "to": "backend",
          "filter": [
            "**/*"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
